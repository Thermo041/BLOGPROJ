<% var _msgs = []; %>
<% (success || []).forEach(function(msg){ if(msg) _msgs.push({ type: 'success', msg: msg }); }); %>
<% (error || []).forEach(function(msg){ if(msg) _msgs.push({ type: 'error', msg: msg }); }); %>
<% if (_msgs.length) { %>
  <div class="toast-wrap fixed top-20 right-5 z-50 flex flex-col gap-2 w-80 max-w-[90vw]">
    <% _msgs.forEach(function(m){ %>
      <% if (m.type === 'success') { %>
        <div class="flash-alert alert alert-success shadow-lg text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
          <span><%= m.msg %></span>
        </div>
      <% } else { %>
        <div class="flash-alert alert alert-error shadow-lg text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          <span><%= m.msg %></span>
        </div>
      <% } %>
    <% }); %>
  </div>
<% } %>
