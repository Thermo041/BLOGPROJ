<article class="group flex flex-col overflow-hidden rounded-2xl border border-base-300/70 bg-base-100 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-base-300/40">
  <a href="/blogs/<%= blog.slug %>" class="block aspect-[16/10] overflow-hidden bg-base-200">
    <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" loading="lazy" class="w-full h-full object-cover transition duration-500 group-hover:scale-105" />
  </a>
  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-center gap-2 mb-3">
      <a href="/blogs?category=<%= encodeURIComponent(blog.category) %>" class="badge badge-sm border-0 bg-primary/10 text-primary font-medium"><%= blog.category %></a>
      <span class="text-xs opacity-50"><%= blog.readingTime %> min read</span>
    </div>
    <h3 class="font-serif text-xl font-semibold leading-snug mb-2">
      <a href="/blogs/<%= blog.slug %>" class="hover:text-primary transition"><%= blog.title %></a>
    </h3>
    <p class="text-sm opacity-70 line-clamp-2 mb-4"><%= blog.description %></p>
    <div class="mt-auto flex items-center justify-between">
      <% if (blog.author) { %>
      <a href="/profile/<%= blog.author._id %>" class="flex items-center gap-2 group/author">
        <img src="<%= blog.author.profilePic %>" class="w-7 h-7 rounded-full object-cover" alt="" />
        <span class="text-sm font-medium group-hover/author:text-primary transition"><%= blog.author.username %></span>
      </a>
      <% } else { %><span></span><% } %>
      <div class="flex items-center gap-3 text-xs opacity-55">
        <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.04 12C3.5 7.5 7.4 4.5 12 4.5s8.5 3 9.96 7.5c-1.46 4.5-5.36 7.5-9.96 7.5S3.5 16.5 2.04 12Z"/><circle cx="12" cy="12" r="3"/></svg><%= blog.views %></span>
        <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg><%= blog.likes ? blog.likes.length : 0 %></span>
      </div>
    </div>
  </div>
</article>
