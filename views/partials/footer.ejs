<footer class="border-t border-base-300/70 mt-20">
  <div class="max-w-6xl mx-auto px-5 py-10 grid gap-8 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <span class="w-7 h-7 rounded-lg bg-primary text-primary-content grid place-items-center font-serif font-bold">B</span>
        <span class="font-serif text-lg font-semibold">BlogSphere</span>
      </div>
      <p class="text-sm opacity-70 max-w-xs">A quiet place for people who like to write and read good things on the web.</p>
    </div>
    <div>
      <h4 class="font-semibold mb-3 text-sm uppercase tracking-wide opacity-60">Discover</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/blogs" class="link link-hover opacity-80">All stories</a></li>
        <% categories.slice(0,4).forEach(function(c){ %>
          <li><a href="/blogs?category=<%= encodeURIComponent(c) %>" class="link link-hover opacity-80"><%= c %></a></li>
        <% }); %>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold mb-3 text-sm uppercase tracking-wide opacity-60">Account</h4>
      <ul class="space-y-2 text-sm">
        <% if (currentUser) { %>
          <li><a href="/dashboard" class="link link-hover opacity-80">Dashboard</a></li>
          <li><a href="/blogs/create" class="link link-hover opacity-80">Write a story</a></li>
        <% } else { %>
          <li><a href="/register" class="link link-hover opacity-80">Create account</a></li>
          <li><a href="/login" class="link link-hover opacity-80">Sign in</a></li>
        <% } %>
      </ul>
    </div>
  </div>
  <div class="border-t border-base-300/70">
    <p class="max-w-6xl mx-auto px-5 py-5 text-xs opacity-60">&copy; <%= new Date().getFullYear() %> BlogSphere. Built for writers.</p>
  </div>
</footer>
