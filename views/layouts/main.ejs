<!DOCTYPE html>
<html lang="en" data-theme="ink">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'BlogSphere' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet" type="text/css" />
  <style type="text/tailwindcss"></style>
  <style>
    [data-theme="ink"] {
      --p: 60% 0.13 50; --pc: 30% 0.04 60;
      --b1: 22% 0.012 70; --b2: 19% 0.012 70; --b3: 27% 0.014 70;
      --bc: 92% 0.01 80; --n: 30% 0.02 70; --nc: 92% 0.01 80;
      --su: 65% 0.16 150; --er: 62% 0.2 25; --wa: 75% 0.16 80; --in: 60% 0.13 250;
      --rounded-box: 1rem; --rounded-btn: 0.6rem;
    }
    [data-theme="paper"] {
      --p: 48% 0.14 45; --pc: 98% 0.01 80;
      --b1: 98% 0.006 85; --b2: 96% 0.008 80; --b3: 91% 0.01 80;
      --bc: 24% 0.02 60; --n: 28% 0.02 60; --nc: 96% 0.006 85;
      --su: 58% 0.15 150; --er: 58% 0.2 25; --wa: 72% 0.15 80; --in: 55% 0.13 250;
      --rounded-box: 1rem; --rounded-btn: 0.6rem;
    }
  </style>
  <link rel="stylesheet" href="/css/style.css" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif: ['Fraunces', 'Georgia', 'serif'],
            sans: ['Inter', 'system-ui', 'sans-serif']
          }
        }
      }
    };
  </script>
</head>
<body class="min-h-screen flex flex-col bg-base-100 text-base-content font-sans antialiased">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <main class="flex-1 w-full">
    <%- body %>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
