<section class="relative overflow-hidden border-b border-base-300/70">
  <div class="hero-grain absolute inset-0 pointer-events-none"></div>
  <div class="max-w-6xl mx-auto px-5 py-20 md:py-28 relative">
    <div class="max-w-2xl">
      <span class="badge badge-lg border-0 bg-primary/10 text-primary mb-5 font-medium">Stories worth your time</span>
      <h1 class="font-serif text-4xl md:text-6xl font-semibold leading-[1.05] tracking-tight">Read, write and share what you really think.</h1>
      <p class="mt-5 text-lg opacity-70 max-w-xl">BlogSphere is a calm corner of the internet for developers and curious minds. No noise, just good writing.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/blogs" class="btn btn-primary rounded-full px-6">Start reading</a>
        <% if (!currentUser) { %><a href="/register" class="btn btn-ghost rounded-full px-6">Become a writer</a><% } else { %><a href="/blogs/create" class="btn btn-ghost rounded-full px-6">Write a story</a><% } %>
      </div>
    </div>
  </div>
</section>

<section class="max-w-6xl mx-auto px-5 py-10">
  <div class="flex flex-wrap gap-2">
    <a href="/blogs" class="btn btn-sm rounded-full btn-outline">All</a>
    <% categories.forEach(function(c){ %>
      <a href="/blogs?category=<%= encodeURIComponent(c) %>" class="btn btn-sm rounded-full btn-ghost bg-base-200/60"><%= c %></a>
    <% }); %>
  </div>
</section>

<% if (featured.length) { %>
<section class="max-w-6xl mx-auto px-5 pb-4">
  <h2 class="font-serif text-2xl font-semibold mb-6">Trending now</h2>
  <div class="grid gap-6 md:grid-cols-3">
    <% featured.forEach(function(blog){ %><%- include('../partials/blog-card', { blog }) %><% }); %>
  </div>
</section>
<% } %>

<section class="max-w-6xl mx-auto px-5 py-10">
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-serif text-2xl font-semibold">Latest stories</h2>
    <a href="/blogs" class="link link-primary text-sm font-medium">View all →</a>
  </div>
  <% if (latest.length) { %>
    <div class="grid gap-6 md:grid-cols-3">
      <% latest.forEach(function(blog){ %><%- include('../partials/blog-card', { blog }) %><% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-16 opacity-60">
      <p class="font-serif text-xl">No stories yet.</p>
      <p class="text-sm mt-1">Be the first to publish something great.</p>
    </div>
  <% } %>
</section>
