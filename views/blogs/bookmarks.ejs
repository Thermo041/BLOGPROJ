<section class="max-w-6xl mx-auto px-5 py-12">
  <h1 class="font-serif text-4xl font-semibold mb-2">Your bookmarks</h1>
  <p class="opacity-60 mb-8">Stories you saved to read later.</p>
  <% if (blogs.length) { %>
    <div class="grid gap-6 md:grid-cols-3">
      <% blogs.forEach(function(blog){ %><%- include('../partials/blog-card', { blog }) %><% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-20 opacity-60">
      <p class="font-serif text-2xl">No bookmarks yet</p>
      <p class="text-sm mt-1">Tap the save icon on any story to keep it here.</p>
      <a href="/blogs" class="btn btn-primary btn-sm rounded-full mt-5">Browse stories</a>
    </div>
  <% } %>
</section>
