<article class="max-w-3xl mx-auto px-5 py-12">
  <div class="mb-6">
    <a href="/blogs?category=<%= encodeURIComponent(blog.category) %>" class="badge border-0 bg-primary/10 text-primary font-medium"><%= blog.category %></a>
    <% if (blog.status === 'draft') { %><span class="badge badge-warning ml-2">Draft</span><% } %>
  </div>
  <h1 class="font-serif text-4xl md:text-5xl font-semibold leading-tight tracking-tight"><%= blog.title %></h1>
  <p class="mt-4 text-xl opacity-70 font-serif italic"><%= blog.description %></p>

  <div class="flex items-center justify-between flex-wrap gap-4 mt-7 pb-7 border-b border-base-300/70">
    <a href="/profile/<%= blog.author._id %>" class="flex items-center gap-3">
      <img src="<%= blog.author.profilePic %>" class="w-11 h-11 rounded-full object-cover" alt="" />
      <div>
        <p class="font-semibold leading-tight"><%= blog.author.username %></p>
        <p class="text-xs opacity-55"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %> · <%= blog.readingTime %> min read</p>
      </div>
    </a>
    <% if (currentUser && (String(currentUser._id) === String(blog.author._id) || currentUser.role === 'admin')) { %>
      <div class="flex gap-2">
        <a href="/blogs/edit/<%= blog._id %>" class="btn btn-sm btn-ghost">Edit</a>
        <form action="/blogs/<%= blog._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this blog?')">
          <button class="btn btn-sm btn-ghost text-error">Delete</button>
        </form>
      </div>
    <% } %>
  </div>

  <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" class="w-full rounded-2xl my-8 aspect-[16/9] object-cover" />

  <div class="prose-content">
    <% blog.content.split(/\n\n+/).forEach(function(p){ %><p><%= p %></p><% }); %>
  </div>

  <% if (blog.tags && blog.tags.length) { %>
    <div class="flex flex-wrap gap-2 mt-8">
      <% blog.tags.forEach(function(t){ %><span class="badge badge-ghost bg-base-200">#<%= t %></span><% }); %>
    </div>
  <% } %>

  <div class="flex items-center gap-3 mt-10 py-4 border-y border-base-300/70 sticky-actions">
    <% var liked = currentUser && blog.likes.some(function(u){ return String(u) === String(currentUser._id); }); %>
    <button data-like="<%= blog._id %>" class="like-btn btn btn-sm rounded-full gap-2 <%= liked ? 'btn-primary active' : 'btn-outline' %>">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
      <span data-count><%= blog.likes.length %></span>
    </button>
    <button data-bookmark="<%= blog._id %>" class="btn btn-sm rounded-full gap-2 <%= bookmarked ? 'btn-primary active' : 'btn-outline' %>">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.5 48.5 0 0 1 11.186 0Z"/></svg>
      <span data-label><%= bookmarked ? 'Saved' : 'Save' %></span>
    </button>
    <span class="ml-auto text-sm opacity-55 flex items-center gap-1" data-views-blog="<%= blog._id %>">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.04 12C3.5 7.5 7.4 4.5 12 4.5s8.5 3 9.96 7.5c-1.46 4.5-5.36 7.5-9.96 7.5S3.5 16.5 2.04 12Z"/><circle cx="12" cy="12" r="3"/></svg>
      <span data-views-count><%= blog.views %></span>&nbsp;views
    </span>
  </div>

  <section id="comments" class="mt-12">
    <h2 class="font-serif text-2xl font-semibold mb-6">Comments (<%= comments.length %>)</h2>
    <% if (currentUser) { %>
      <form action="/blogs/<%= blog._id %>/comment" method="POST" class="mb-8">
        <textarea name="text" rows="3" required placeholder="Share your thoughts…" class="textarea textarea-bordered w-full"></textarea>
        <div class="flex justify-end mt-2"><button class="btn btn-primary btn-sm">Post comment</button></div>
      </form>
    <% } else { %>
      <div class="alert bg-base-200 border border-base-300/70 mb-8 text-sm"><a href="/login" class="link link-primary">Sign in</a> to join the conversation.</div>
    <% } %>

    <div class="space-y-5">
      <% if (!comments.length) { %><p class="opacity-55 text-sm">No comments yet. Be the first.</p><% } %>
      <% comments.forEach(function(c){ %>
        <div class="flex gap-3">
          <img src="<%= c.user.profilePic %>" class="w-9 h-9 rounded-full object-cover shrink-0" alt="" />
          <div class="flex-1 bg-base-200/50 rounded-2xl rounded-tl-sm px-4 py-3">
            <div class="flex items-center justify-between gap-2">
              <span class="font-semibold text-sm"><%= c.user.username %></span>
              <span class="text-xs opacity-50"><%= new Date(c.createdAt).toLocaleDateString() %></span>
            </div>
            <p class="text-sm mt-1 opacity-90"><%= c.text %></p>
            <% if (currentUser && (String(currentUser._id) === String(c.user._id) || currentUser.role === 'admin')) { %>
              <form action="/comments/<%= c._id %>?_method=DELETE" method="POST" class="mt-1">
                <button class="text-xs link link-error opacity-70">Delete</button>
              </form>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <% if (related.length) { %>
    <section class="mt-16 pt-10 border-t border-base-300/70">
      <h2 class="font-serif text-2xl font-semibold mb-6">More in <%= blog.category %></h2>
      <div class="grid gap-4 sm:grid-cols-3">
        <% related.forEach(function(r){ %>
          <a href="/blogs/<%= r.slug %>" class="group block">
            <div class="aspect-[16/10] rounded-xl overflow-hidden bg-base-200 mb-2"><img src="<%= r.coverImage %>" class="w-full h-full object-cover group-hover:scale-105 transition" alt="" /></div>
            <h3 class="font-serif font-semibold leading-snug group-hover:text-primary transition"><%= r.title %></h3>
          </a>
        <% }); %>
      </div>
    </section>
  <% } %>
</article>
