<section class="max-w-4xl mx-auto px-5 py-12">
  <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 pb-8 border-b border-base-300/70">
    <img src="<%= profileUser.avatar %>" class="w-24 h-24 rounded-full object-cover ring ring-base-300 ring-offset-base-100 ring-offset-2 bg-base-200" alt="" />
    <div class="text-center sm:text-left flex-1">
      <h1 class="font-serif text-3xl font-semibold"><%= profileUser.username %></h1>
      <% if (profileUser.role === 'admin') { %><span class="badge badge-primary badge-sm mt-1">Admin</span><% } %>
      <p class="opacity-70 mt-2 max-w-lg"><%= profileUser.bio || 'This writer has not added a bio yet.' %></p>
      <p class="text-sm opacity-50 mt-3"><%= blogs.length %> published <%= blogs.length === 1 ? 'story' : 'stories' %> · Joined <%= new Date(profileUser.createdAt || profileUser._id.getTimestamp()).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></p>
    </div>
    <% if (currentUser && String(currentUser._id) === String(profileUser._id)) { %>
      <a href="/settings" class="btn btn-outline btn-sm">Edit profile</a>
    <% } %>
  </div>

  <% if (blogs.length) { %>
    <div class="grid gap-6 md:grid-cols-2 mt-8">
      <% blogs.forEach(function(blog){ blog.author = profileUser; %><%- include('../partials/blog-card', { blog }) %><% }); %>
    </div>
  <% } else { %>
    <p class="text-center opacity-55 py-16 font-serif text-xl">No published stories yet.</p>
  <% } %>
</section>
